# Agent-S3 local config example
# Copy to env.txt and fill real values.
# env.txt is ignored by git.

# Main model endpoint
oai_base_url: https://right.codes/codex/v1
oai_api: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
model: gpt-5.4
model_reasoning_effort: medium

# Reflection control
reflection_mode: on_failure

# Optional Doubao-style endpoint values if you run through ARK
# ep-id: ep-xxxxxxxxxxxxx-xxxxx
# api-key: ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ARK_API_KEY: ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
