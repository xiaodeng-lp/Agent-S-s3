# Agent-S3 local config example
# Copy to env.txt and fill real values.
# env.txt is ignored by git.

# Main model endpoint
oai_base_url: https://right.codes/codex/v1
oai_api: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
model: gpt-5.4
model_reasoning_effort: medium

# Reflection control
reflection_mode: on_failure

# Optional Doubao / ARK values
# Main model on ARK:
#   - GUI sends the ARK Endpoint ID as --model
#   - use a key that has access to that endpoint
# ep-id: ep-xxxxxxxxxxxxx-xxxxx
# api-key: ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Grounding model on ARK:
#   - default grounding model is doubao-seed-1-6-vision-250815
#   - use ARK_API_KEY if grounding should use a different key
# ARK_API_KEY: ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Optional explicit aliases for clarity
# VOLCANO_ENDPOINT_ID: ep-xxxxxxxxxxxxx-xxxxx
# VOLCANO_API_KEY: ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# GROUND_API_KEY: ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
