{
  "name": "飞书发消息",
  "description": "在飞书群聊或私聊中发送一条消息",
  "params": [
    {"name": "recipient", "label": "联系人/群名", "placeholder": "例如：项目组"},
    {"name": "message",   "label": "消息内容",   "placeholder": "例如：今天下午3点开会"}
  ],
  "steps": [
    {"type": "hotkey",  "keys": ["ctrl", "alt", "f"],         "comment": "唤起飞书搜索（全局快捷键）"},
    {"type": "wait",    "seconds": 0.8},
    {"type": "type",    "text": "{{recipient}}"},
    {"type": "wait",    "seconds": 1.2},
    {"type": "press",   "key": "enter"},
    {"type": "wait",    "seconds": 1.0},
    {"type": "type",    "text": "{{message}}"},
    {"type": "press",   "key": "enter"}
  ]
}
